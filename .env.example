# PataFundi Environment Variables
# OnSpace Cloud backend — already configured by default

# Optional: Override with custom backend URL
# VITE_API_URL=https://rootjhvyvhrdummdroot.backend.onspace.ai/functions/v1

# Optional: Socket URL (not required — platform uses polling)
# VITE_SOCKET_URL=

# Optional: Google Maps (for production map features)
# VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Demo Accounts (pre-seeded in database)
# Customer: demo@patafundi.com / Demo@2024!
# Fundi:    fundi@patafundi.com / Fundi@2024!
# Admin:    admin@patafundi.com / Admin@2024!
