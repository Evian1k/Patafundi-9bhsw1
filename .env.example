# PataFundi Environment Variables
# Copy this file to .env and fill in the values

# ─── Required ────────────────────────────────────────────────────────────────
# Backend API base URL (no trailing slash)
VITE_API_URL=https://patafundifullversion.onrender.com/api

# Socket.IO server URL (no path suffix)
VITE_SOCKET_URL=https://patafundifullversion.onrender.com

# ─── Optional ────────────────────────────────────────────────────────────────
# Google Maps JavaScript API key (enables live map tracking)
# Without this, a styled fallback map is shown
VITE_GOOGLE_MAPS_API_KEY=

# Maximum acceptable GPS accuracy in meters (default: 200)
VITE_MAX_GPS_ACCURACY_METERS=200

# ─── Backend-only (not exposed to frontend) ──────────────────────────────────
# Database
# DATABASE_URL=postgresql://user:pass@host:5432/patafundi

# JWT
# JWT_SECRET=your-jwt-secret
# JWT_EXPIRES_IN=7d

# OTP
# OTP_SECRET=your-otp-secret
# OTP_EXPIRES_MINUTES=10

# M-Pesa (Safaricom Daraja)
# MPESA_CONSUMER_KEY=
# MPESA_CONSUMER_SECRET=
# MPESA_SHORTCODE=
# MPESA_PASSKEY=
# MPESA_CALLBACK_URL=https://patafundifullversion.onrender.com/api/payments/mpesa-callback
# MPESA_ENVIRONMENT=sandbox

# Email (SMTP)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@patafundi.com

# App URLs
# FRONTEND_URL=https://patafundi.vercel.app
# BACKEND_URL=https://patafundifullversion.onrender.com
