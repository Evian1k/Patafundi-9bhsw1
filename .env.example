# PataFundi Frontend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit your actual .env file to version control.

# ── Required ──────────────────────────────────────────────────────────────────
# Backend API base URL (no trailing slash)
VITE_API_URL=https://your-backend.onrender.com/api

# Socket.IO server URL (same host as API, without /api)
VITE_SOCKET_URL=https://your-backend.onrender.com

# ── Optional ──────────────────────────────────────────────────────────────────
# Google Maps API key (for map components)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Maximum acceptable GPS accuracy in meters (default: 200)
VITE_MAX_GPS_ACCURACY_METERS=200
