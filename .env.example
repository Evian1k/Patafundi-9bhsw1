# PataFundi Environment Variables

# ── Frontend (Vite) ────────────────────────────────────────────────────────────
# Local dev: leave empty to use Vite proxy (/api → http://127.0.0.1:4000)
# Production / Vercel: set to your Render backend origin (no trailing slash required)
VITE_API_URL=
# Socket.IO — auto-derived from VITE_API_URL if omitted; set explicitly for production
VITE_SOCKET_URL=

# Location provider: false = OpenStreetMap (free), true = Google Maps (requires keys below)
VITE_USE_GOOGLE_MAPS=false

# Google Maps (client-side maps rendering)
VITE_GOOGLE_MAPS_API_KEY=

# Production (Vercel env vars + .env.production for local builds):
# VITE_API_URL=https://patafundi-9bhsw1.onrender.com
# VITE_SOCKET_URL=https://patafundi-9bhsw1.onrender.com

# ── Backend (Render / local) ─────────────────────────────────────────────────
PORT=4000
# Primary frontend URL (your Vercel deployment)
FRONTEND_ORIGIN=http://127.0.0.1:8080
# Production Render: https://patafundi.vercel.app
# Extra allowed origins, comma-separated
CORS_ORIGINS=

# PostgreSQL — REQUIRED on Windows (PGlite embedded DB may crash on Windows).
#
# OPTION A — Docker (recommended, zero setup):
#   1. Install Docker Desktop: https://www.docker.com/products/docker-desktop
#   2. Run:  docker compose up -d
#   3. Use this DATABASE_URL:
DATABASE_URL=postgres://postgres:postgres@localhost:5432/patafundi
#
# OPTION B — Local Postgres install:
#   1. Install Postgres 16+ from https://www.postgresql.org/download/windows/
#   2. Create database:  createdb patafundi  (or via pgAdmin)
#   3. Use the same DATABASE_URL as above.
#
# OPTION C — Mac/Linux: leave DATABASE_URL empty to use PGlite (embedded DB).
#   PGlite may NOT work on Windows — if you see "Aborted(). Build with -sASSERTIONS",
#   switch to Docker (Option A) or local Postgres (Option B).

# Auth secrets (generate unique values for production)
JWT_SECRET=dev-jwt-secret-change-in-production
REFRESH_TOKEN_SECRET=dev-refresh-secret-change-in-production
COOKIE_SECURE=false

# Email OTP (Resend — use sandbox sender until domain is verified)
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev

# Location provider: false = OpenStreetMap (free), true = Google Maps (requires keys below)
USE_GOOGLE_MAPS=false

# Google Maps server-side geocoding/directions
GOOGLE_MAPS_SERVER_KEY=

# M-Pesa Daraja (required for real payments)
MPESA_BASE_URL=https://api.safaricom.co.ke
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_CALLBACK_URL=
MPESA_CALLBACK_SECRET=
MPESA_TIMEOUT_URL=
MPESA_RESULT_URL=

# Cloudflare R2 storage (production — local fallback when unset)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=patafundi
# R2_PUBLIC_URL is optional; files are never served publicly — use signed URLs only
R2_PUBLIC_URL=

# Optional: AWS Rekognition for production-grade face matching (set to true when configured)
AWS_REGION=us-east-1
AWS_REKOGNITION_ENABLED=false

# Demo accounts (created by npm run db:seed)
# Customer: demo@patafundi.com / Demo@2024!
# Fundi:    fundi@patafundi.com / Fundi@2024!
# Admin:    admin@patafundi.com / Admin@2024!
