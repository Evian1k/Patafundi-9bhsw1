# PataFundi Environment Variables

# Frontend API — leave blank in local dev to use Vite proxy (/api -> :4000)
VITE_API_URL=

# Socket.IO — leave blank to use same origin as the frontend
VITE_SOCKET_URL=

# Google Maps (client-side maps rendering)
VITE_GOOGLE_MAPS_API_KEY=

# Backend
PORT=4000
FRONTEND_ORIGIN=http://127.0.0.1:8080

# PostgreSQL (use docker-compose up -d for local postgres)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/patafundi

# Auth secrets (generate unique values for production)
JWT_SECRET=dev-jwt-secret-change-in-production
REFRESH_TOKEN_SECRET=dev-refresh-secret-change-in-production
COOKIE_SECURE=false

# Google Maps server-side geocoding/directions (optional; haversine fallback used if unset)
GOOGLE_MAPS_SERVER_KEY=

# M-Pesa Daraja (required for real payments)
MPESA_BASE_URL=https://api.safaricom.co.ke
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_CALLBACK_URL=
MPESA_TIMEOUT_URL=
MPESA_RESULT_URL=

# Demo accounts (created by npm run db:seed)
# Customer: demo@patafundi.com / Demo@2024!
# Fundi:    fundi@patafundi.com / Fundi@2024!
# Admin:    admin@patafundi.com / Admin@2024!
